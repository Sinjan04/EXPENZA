generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(cuid())
  name         String
  email        String        @unique
  password     String
  createdAt    DateTime      @default(now())
  budgets      Budget[]
  transactions Transaction[]
}

model Transaction {
  id        String   @id @default(cuid())
  amount    Float
  type      String
  category  String
  note      String?
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
}

model Budget {
  id        String   @id @default(cuid())
  category  String
  limit     Float
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
}
